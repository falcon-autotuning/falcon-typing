@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# falcon-typing only requires falcon_core at consumer link time.
# falcon_core is installed at /opt/falcon; consumers may need to hint this.
find_dependency(falcon_core REQUIRED)

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/falcon-typing-targets.cmake")

# Provides:
#   falcon::falcon-typing  — shared library with PrimitiveTypes + FfiHelpers

check_required_components(falcon-typing)
